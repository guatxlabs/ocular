FROM python:3.11-slim

WORKDIR /app

# Le broker est le SEUL tier autorisé à parler à Docker (socket monté par compose) :
# il a donc besoin du CLI docker pour lancer/tuer les conteneurs runner_analysis.
RUN apt-get update \
    && apt-get install -y --no-install-recommends docker.io \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
COPY engine/ ./engine/
COPY bus/ ./bus/
COPY broker/ ./broker/

RUN pip install --no-cache-dir redis pydantic

CMD ["python", "-m", "broker.main"]
