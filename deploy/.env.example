REDIS_URL=redis://redis:6379
OCULAR_TOKEN=change-me-to-a-strong-random-token

# Interface d'écoute de l'API. Défaut sûr = loopback SEULEMENT.
# L'API (/sessions, proxy noVNC) n'est protégée que par un Bearer statique, sans
# rotation ni rate-limit : ne l'expose au réseau QUE derrière un reverse-proxy
# authentifiant (modèle du §1). Pour exposer explicitement : OCULAR_BIND=0.0.0.0
# OCULAR_BIND=127.0.0.1
# Token admin : requis pour SUPPRIMER / PURGER des analyses sauvegardées.
# Tape EXACTEMENT cette valeur dans le champ « Token administrateur » de l'UI (page Admin).
# Laisse VIDE (OCULAR_ADMIN_TOKEN=) pour désactiver totalement l'admin par token.
OCULAR_ADMIN_TOKEN=ocular-admin-change-me

# Identité IdP (forward-auth) — OPTIONNEL, désactivé par défaut.
# N'activer QUE derrière un reverse-proxy authentifié qui STRIPPE l'en-tête client (cf. README).
# OCULAR_TRUST_FORWARD_AUTH=1
# OCULAR_FORWARD_USER_HEADER=X-Forwarded-User
# OCULAR_FORWARD_EMAIL_HEADER=X-Forwarded-Email
# Rôle admin via groupe IdP (nécessite OCULAR_TRUST_FORWARD_AUTH=1 + strip proxy de X-Forwarded-Groups).
# OCULAR_ADMIN_GROUP=ocular-admins
# OCULAR_FORWARD_GROUPS_HEADER=X-Forwarded-Groups
