FROM python:3.11-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget ca-certificates xvfb xdotool scrot \
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 \
    libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 \
    libcairo2 libasound2 libgtk-3-0 libdbus-glib-1-2 libxt6 fonts-liberation \
    && rm -rf /var/lib/apt/lists/*
# playwright PINNÃ (pas la derniÃĻre version) : le binaire Camoufox fetchÃĐ plus
# bas est un Firefox patchÃĐ v135.0.1-beta.24 (protocole d'automation Juggler
# figÃĐ Ã  cette release). `pip install playwright` sans version prend la
# derniÃĻre (1.61.0 au moment d'ÃĐcrire) dont le driver Juggler a dÃĐrivÃĐ du
# protocole de ce Firefox v135 -- observÃĐ empiriquement : le lancement du
# navigateur (`BrowserType.launch`) reste bloquÃĐ indÃĐfiniment (deadlock de
# handshake, 180s de timeout Playwright), IDENTIQUE avec
# `--security-opt seccomp=unconfined` (donc PAS un blocage seccomp : le
# process Firefox reste juste en lecture bloquante sur le pipe
# `-wait-for-browser`, en attente d'un signal du driver Node qui ne vient
# jamais). `playwright==1.49.1` (contemporain de ce build Camoufox) rÃĐsout le
# handshake -- testÃĐ empiriquement : navigation + capture OK.
RUN pip install --no-cache-dir camoufox[geoip] opencv-python-headless numpy "playwright==1.49.1" pydantic
# Patch Playwright coreBundle (survie erreurs JS CF/Auth0)
RUN CB=$(python3 -c "import playwright,os;print(os.path.join(os.path.dirname(playwright.__file__),'driver/package/lib/coreBundle.js'))") \
    && sed -i 's/const pageError = { error, location: location2 };/const pageError = { error, location: location2 || { url: "", lineNumber: 0, columnNumber: 0 } };/' "$CB" || true

# --- Binaire Camoufox : DOIT vivre dans une couche IMAGE en lecture seule, pas
# dans /work (tmpfs ÃĐphÃĐmÃĻre montÃĐ au runtime). Au runtime le conteneur tourne
# --user 10001:10001, donc le binaire doit ÃŠtre lisible (pas forcÃĐment
# possÃĐdÃĐ) par cet UID, dans un HOME persistant de l'image (/opt/camoufox) --
# pas /root (racine par dÃĐfaut du fetch, hors de portÃĐe d'un UID non-root au
# runtime) ni /work (tmpfs, recrÃĐÃĐ vide Ã  chaque dÃĐmarrage de conteneur).
#
# Tentative initiale : faire le fetch en tant qu'UID 10001 (`su runner -c
# "python3 -m camoufox fetch"`) AVANT le `USER 10001` final, avec
# HOME=/opt/camoufox dÃĐjÃ  rÃĐglÃĐ. Ãa ÃCHOUE :
#   PermissionError: [Errno 13] Permission denied:
#   '/usr/local/lib/python3.11/site-packages/camoufox/GeoLite2-City.mmdb'
# `camoufox[geoip]` tÃĐlÃĐcharge la base GeoIP DANS l'arborescence pip
# (site-packages/camoufox/), pas sous $HOME -- ce chemin appartient Ã  root
# (crÃĐÃĐ par `pip install` exÃĐcutÃĐ en root plus haut) et n'est pas accessible
# en ÃĐcriture Ã  l'UID 10001. Donc le fetch DOIT s'exÃĐcuter en root (seul le
# binaire Camoufox lui-mÃŠme respecte $HOME ; le sidecar GeoIP non).
#
# Fix retenu : fetch en ROOT (ÃĐcriture OK partout) avec HOME=/opt/camoufox
# dÃĐjÃ  positionnÃĐ -> le binaire Camoufox atterrit dans /opt/camoufox (couche
# image, lecture seule au runtime) et la mmdb GeoIP dans site-packages
# (ÃĐgalement couche image). On chown ensuite /opt/camoufox vers 10001:10001
# par cohÃĐrence/traÃ§abilitÃĐ, mÃŠme si la lecture seule suffirait dÃĐjÃ  (fichiers
# world-readable par dÃĐfaut aprÃĻs un `pip install`/fetch en root).
RUN useradd -u 10001 -m runner \
    && mkdir -p /opt/camoufox /work \
    && chown -R 10001:10001 /opt/camoufox /work
ENV HOME=/opt/camoufox
RUN python3 -m camoufox fetch && chown -R 10001:10001 /opt/camoufox

# Bug de nommage upstream camoufox==0.4.11 : `camoufox/utils.py` construit
# FONTCONFIG_PATH via get_path("fontconfig/<os>") mais le binaire fetchÃĐ
# stocke ces fichiers sous "fontconfigs/<os>" (avec un s) -- constatÃĐ
# empiriquement (le dossier "fontconfig" n'existe pas, seul "fontconfigs"
# existe). Sans correctif, FONTCONFIG_PATH pointe vers un rÃĐpertoire
# inexistant : fontconfig retombe sur les polices systÃĻme au lieu du jeu de
# polices bundlÃĐes anti-fingerprinting de Camoufox (rÃĐgression furtivitÃĐ,
# silencieuse). Symlink minimal qui fait pointer "fontconfig" vers
# "fontconfigs" existant, sans toucher au code Python vendored.
RUN ln -s fontconfigs /opt/camoufox/.cache/camoufox/fontconfig

COPY engine/ ./engine/
COPY ocular_settings.py ocular_logging.py ./
COPY runner_recon/ ./runner_recon/
COPY runner_recon/vision.py ./vision.py
# vision.py rÃĐsout son template Turnstile via son PROPRE __file__ (voir
# runner_recon/vision.py) ; comme vision.py est aplati Ã  la racine /app (ligne
# ci-dessus), le template doit ÃŠtre copiÃĐ au mÃŠme niveau, pas seulement sous
# runner_recon/ -- sinon `cv2.imread` ÃĐchoue silencieusement (try/except dans
# capture.py) et la dÃĐtection Turnstile est un no-op silencieux.
COPY runner_recon/turnstile_checkbox.png ./turnstile_checkbox.png
COPY runner_recon/entrypoint_recon.sh /entrypoint_recon.sh
RUN chmod +x /entrypoint_recon.sh && chown -R 10001:10001 /app

# --- CORRECTIF CRITIQUE (celui qui dÃĐbloque le smoke durci) ---
# `HOME=/opt/camoufox` (comme rÃĐglÃĐ pendant le build ci-dessus) casse tout au
# RUNTIME dÃĻs que `--read-only` est appliquÃĐ : constatÃĐ empiriquement en
# isolant flag par flag (`--cap-drop ALL` seul => OK ; `--read-only`+tmpfs
# seul, SANS cap-drop => bloquÃĐ quand mÃŠme) que c'est spÃĐcifiquement
# `--read-only` le coupable, PAS seccomp (testÃĐ jusqu'Ã 
# `--security-opt seccomp=unconfined` : mÃŠme blocage) ni `--cap-drop ALL`
# (testÃĐ seul : navigation OK). Sous `--read-only`, `/opt/camoufox` devient
# rÃĐellement en lecture seule (couche image) ; or de nombreux composants
# (fontconfig, ICEauthority X11, dconf/GTK, ...) ÃĐcrivent des fichiers de
# profil/cache sous `$HOME` par dÃĐfaut -- ces ÃĐcritures ÃĐchouent
# silencieusement, et la combinaison finit par bloquer indÃĐfiniment le
# handshake Playwright<->Firefox (`BrowserType.launch` timeout 180s, aucune
# erreur explicite).
#
# Fix : dÃĐcoupler HOME (rÃĻgle oÃđ les composants tiers ÃĐcrivent leurs
# dotfiles -> DOIT ÃŠtre inscriptible -> /work, tmpfs montÃĐ au runtime) de
# XDG_CACHE_HOME (rÃĻgle oÃđ *camoufox* rÃĐsout son propre binaire/fontconfig
# via `platformdirs.user_cache_dir("camoufox")`, qui consulte XDG_CACHE_HOME
# EN PRIORITÃ sur HOME -- donc rester pointÃĐ sur la couche image en lecture
# seule oÃđ `camoufox fetch` a ÃĐcrit plus haut, sans avoir besoin d'ÃĐcrire dedans
# au runtime, uniquement de le lire). VÃĐrifiÃĐ empiriquement : avec ce split,
# le smoke durci complet (cap-drop ALL + read-only + tmpfs + user 10001)
# navigue et ÃĐmet un wrapper valide.
ENV HOME=/work XDG_CACHE_HOME=/opt/camoufox/.cache TMPDIR=/work DISPLAY=:99
USER 10001
ENTRYPOINT ["/entrypoint_recon.sh"]
