      "items": {
        "$ref": "#/$defs/Screenshot"
      },
      "title": "Screenshots",
      "type": "array"
    },
    "network": {
      "items": {
        "$ref": "#/$defs/NetworkEntry"
      },
      "title": "Network",
      "type": "array"
    },
    "console": {
      "items": {
        "$ref": "#/$defs/ConsoleEntry"
      },
      "title": "Console",
      "type": "array"
    },
    "dom": {
      "$ref": "#/$defs/DomInfo"
    },
    "static_findings": {
      "items": {
        "$ref": "#/$defs/StaticFinding"
      },
      "title": "Static Findings",
      "type": "array"
    },
    "dynamic_steps": {
      "items": {
        "$ref": "#/$defs/DynamicStep"
      },
      "title": "Dynamic Steps",
      "type": "array"
